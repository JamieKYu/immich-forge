# --- Immich (broker holds these; the browser never sees them) ---
IMMICH_BASE_URL=http://immich-server:2283
IMMICH_API_KEY=replace-with-your-immich-api-key

# --- Auth on the Forge API itself (clients send: Authorization: Bearer <token>) ---
# REQUIRED. If left empty the API fails closed (503) so the Immich proxy is never
# exposed unauthenticated. Generate one with: openssl rand -hex 32
FORGE_API_TOKEN=replace-with-a-long-random-token

# Optional: comma-separated CORS allow-list. Leave empty (recommended) — the
# extension reaches Forge via its granted host permission, which CORS does not
# gate, so opening CORS only widens the attack surface. Set only for a custom
# non-extension web client, e.g. https://my-tool.example.com
FORGE_CORS_ORIGINS=

# --- GPU / pipeline ---
FORGE_DEVICE=cuda
FORGE_WEIGHTS_DIR=weights
FORGE_TILE_SIZE=512
FORGE_MAX_IMAGE_PIXELS=40000000
FORGE_MAX_OUTPUT_PIXELS=100000000    # upscale factor is clamped to keep output under this

# Backends: each falls back to a classical/no-op impl when its weights/libs are absent.
# Upgrading from an older .env? Update these values too, then `docker compose up -d`
# (a plain `restart` does NOT re-read this file).
FORGE_UPSCALE_BACKEND=realesrgan     # realesrgan | lanczos
FORGE_FACE_BACKEND=gfpgan            # gfpgan | codeformer | none   (gfpgan is wired)
FORGE_COLORIZE_BACKEND=ddcolor       # ddcolor | none               (ddcolor is wired)

# --- Jobs ---
FORGE_JOB_TTL_SECONDS=3600
FORGE_MAX_CONCURRENT_GPU_JOBS=1
